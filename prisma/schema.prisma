generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Order {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  items         String
  total         Float
  paymentMethod String    @default("cash")
  userName      String?
  userEmail     String?
  scheduledDate DateTime?
}

model ProductOverride {
  id        String   @id
  data      String   @default("{}")
  updatedAt DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userName  String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
}

model GameConfig {
  id          String @id @default("singleton")
  winPercent  Float  @default(15)
  discountUsd Float  @default(3)
  discountKrw Int    @default(4000)
}

model Coupon {
  code        String   @id
  discountUsd Float
  discountKrw Int
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())
  winnerEmail String?
}

model GamePlay {
  id       String   @id @default(cuid())
  email    String
  playedAt DateTime @default(now())

  @@index([email])
}
